REACT_APP_API_URL=https://your-api.example.com/api
REACT_APP_FILE_SERVER_BASE=https://your-cdn-or-files.example.com
REACT_APP_ENV=development
GENERATE_SOURCEMAP=false

# Backend API base URL (must include /api). Used for auth, courses, etc.
# Production example: https://lms-sifu.tutorla.tech/api
REACT_APP_API_URL=https://lms-sifu.tutorla.tech/api

# Optional: file server base URL (for uploads, profile images). If not set, derived from REACT_APP_API_URL.
# REACT_APP_FILE_SERVER_BASE=https://lms-sifu.tutorla.tech

# Environment (development | production)
REACT_APP_ENV=development
